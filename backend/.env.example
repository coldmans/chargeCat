PORT=8787
PUBLIC_BASE_URL=https://your-chargecat-api.example.com

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=chargecat_app
MYSQL_PASSWORD=chargecat_app_password
MYSQL_DATABASE=chargecat
MYSQL_CONNECTION_LIMIT=10

# Azure MySQL Flexible Server 등 TLS 강제 환경에서만 true로 설정.
# MYSQL_SSL_CA_PATH가 지정되면 해당 번들을 검증용 CA로 사용하며, 자동으로 SSL 활성화.
MYSQL_SSL=false
MYSQL_SSL_CA_PATH=
MYSQL_SSL_REJECT_UNAUTHORIZED=true

ASSET_CATALOG_PATH=./assets/catalog.json
ASSET_FILES_PATH=./assets/files

LEMON_API_KEY=your_lemonsqueezy_api_key
LEMON_WEBHOOK_SECRET=your_lemonsqueezy_webhook_secret
LEMON_STORE_ID=1
LEMON_PRODUCT_ID=1
LEMON_VARIANT_ID=1

TOSS_WIDGET_CLIENT_KEY=test_gck_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_SECRET_KEY=test_sk_docs_Ovk5rk1EwkEbP0W43n07xlzm
TOSS_WIDGET_VARIANT_KEY=DEFAULT
PRO_PRICE_KRW=3900
DEFAULT_CHECKOUT_PROVIDER=toss

APP_CUSTOM_SCHEME=chargecat
MY_ORDERS_URL=https://app.lemonsqueezy.com/my-orders
SUPPORT_URL=https://github.com/coldmans/chargeCat/issues
APP_DOWNLOAD_URL=https://github.com/coldmans/chargeCat/releases
